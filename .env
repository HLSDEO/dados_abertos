# ──────────────────────────────────────────────────────────────────────────────
# .env — variáveis do projeto dados_abertos
# NUNCA commite este arquivo com senhas reais.
# Adicione .env ao .gitignore.
# ──────────────────────────────────────────────────────────────────────────────
 
# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
 
# ── ETL ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=150000
WORKERS=4

 
# ── Pipeline Neo4j ────────────────────────────────────────────────────────────
# Linhas lidas do CSV por vez durante o pipeline (diferente do CHUNK_SIZE do download)
NEO4J_CHUNK=20000
 
# Linhas por UNWIND no Cypher (maior = menos round-trips, mais RAM no Neo4j)
NEO4J_BATCH=2000
 
# Sessões Neo4j paralelas no pipeline (Estab + Socios rodam simultâneos)
PIPELINE_WORKERS=2