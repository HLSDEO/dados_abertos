 
# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_HEAP_INITIAL_SIZE=4g
NEO4J_HEAP_MAX_SIZE=8g
NEO4J_PAGECACHE_SIZE=8g
NEO4J_TRANSACTION_TIMEOUT=120s
NEO4J_QUERY_TIMEOUT_SECONDS=120
NEO4J_MAX_CONNECTION_POOL_SIZE=20

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000

# API profile - dev (8 cores / 24 GB RAM)
API_WORKERS=4
API_THREADS=2
API_TIMEOUT_SECONDS=120
CACHE_ENABLED=1
REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TTL_SECONDS=60
SLOW_QUERY_THRESHOLD_SECONDS=2.0
NEO4J_QUERY_TIMEOUT_SECONDS=120
NEO4J_MAX_CONNECTION_POOL_SIZE=20

# Neo4j transaction timeout
NEO4J_TRANSACTION_TIMEOUT=120s

# ETL
CHUNK_SIZE=150000
WORKERS=4
NEO4J_CHUNK=20000
NEO4J_BATCH=2000
PIPELINE_WORKERS=2
GDS_PROFILE=auto
GDS_MAX_MEMORY_GB=8
GDS_BETWEENNESS_SAMPLING_SIZE=600
